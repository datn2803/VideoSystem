# ── HyperFrames render service ──
# Cổng HTTP service lắng nghe (Docker map 8080:8080)
PORT=8080

# Bearer token bắt buộc cho POST /render. PHẢI là chuỗi ngẫu nhiên mạnh (≥32 ký tự).
# Sinh: openssl rand -hex 32
RENDER_TOKEN=

# ── Supabase Storage (nơi upload MP4 đã render) ──
# Nếu BỎ TRỐNG cả 3 dòng dưới → service trả file MP4 trực tiếp thay vì URL.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=videos

# ── Lõi render (Phase 3) ──
# RENDER_ENGINE: "playwright" = frame-stepping tự chủ. ⚠ BẮT BUỘC "playwright" để b-roll <video> Pexels
# (C2 HYBRID) chạy đúng — engine "cli" (mặc định) làm <video> ĐỨNG HÌNH. (Chỉ ảnh AI thuần thì "cli" cũng được.)
RENDER_ENGINE=playwright
# FPS render (giới hạn 12–30). 24 = cinematic (mặc định).
RENDER_FPS=24

# ── C2 HYBRID — clip b-roll Pexels thật (cảnh concept). App gửi URL clip; service tải về file local để seek. ──
# Key FREE tại pexels.com/api. App thiếu key → tự fallback ảnh AI. (Service KHÔNG bắt buộc key này để render.)
PEXELS_API_KEY=

# ── C4 AUTO-EDITOR — kiểu cutaway (bám VIDEO MẪU: full khung jump-cut CHỦ ĐẠO, split THƯA) ──
# SPLIT_SCREEN_EVERY điều khiển bao nhiêu cutaway dùng split-screen (nửa trên b-roll + nửa dưới mặt C1):
#   0  = KHÔNG split — MỌI cutaway FULL KHUNG jump-cut (GIỐNG MẪU NHẤT). ⭐ Đặt =0 nếu muốn bám mẫu tuyệt đối.
#        (Đây cũng là CODE default khi KHÔNG khai báo dòng này.)
#   4  = full khung CHỦ ĐẠO + cứ 4 cutaway thì 1 cái split (lấp headroom). ← giá trị SHIP dưới đây (full + split thưa).
#   1  = MỌI cutaway split (kiểu cũ PR#16/#17 — toàn split; KHÔNG bám mẫu).
# (Bỏ trống dòng này + đặt SPLIT_SCREEN=1 = tương thích ngược = every 1 = toàn split.)
SPLIT_SCREEN_EVERY=4
# Tỉ lệ nửa trên (b-roll) khi split — 0.4–0.7. 0.5 = mặt C1 nửa dưới rộng (bớt cắt ngang mặt).
BROLL_SPLIT_TOP_FRAC=0.5
# Vị trí crop band MẶT C1 (px từ đỉnh khung C1). Chỉnh để mặt nằm GỌN trong nửa dưới, không bị mép b-roll
# cắt ngang miệng. ⚠ Phụ thuộc KHUNG C1 thật — soi 1 frame split rồi căn lại nếu cần.
BROLL_SPLIT_FACE_Y=120

# ── C2 B-ROLL — KÉO SÁNG (khớp mẫu sáng TB YAVG ~143) + TÔNG ẤM ──
# clip-bright adaptive (server đo luma mỗi ảnh): brightness = clamp(TARGET/luma, 1.0, MAX). Cảnh tối kéo
# mạnh, cảnh sáng giữ ~1.0 (không cháy). Nâng TARGET/MAX = sáng hơn. (Mặc định 195 / 2.3.)
BROLL_GRADE_TARGET=195
BROLL_GRADE_MAX=2.0
# Tông ấm nhẹ toàn khung lúc ghép C4 (đồng tông mẫu VAVG ~136). =0 để TẮT; hoặc override công thức ffmpeg.
BROLL_WARM=1
# BROLL_WARM_FILTER=colorbalance=rm=0.04:rh=0.03:bs=-0.03:bh=-0.04,eq=saturation=1.04
# Ngưỡng loại cảnh ĐEN (luma < ngưỡng → bỏ cutaway, tránh nửa-trên-đen-thui). Mặc định 30.
BROLL_DARK_LUMA_MIN=30

# ── Cloudflare Tunnel — expose service ra Internet cho app Vercel (khi chạy LOCAL trên Mac) ──
# Token "remote-managed tunnel": Cloudflare Zero Trust › Networks › Tunnels › tạo tunnel → copy token.
# Public hostname của tunnel TRỎ VỀ: http://hf-render:8080 (tên service trên compose network). Xem RUN_LOCAL.md.
CLOUDFLARE_TUNNEL_TOKEN=

# (TUỲ CHỌN) URL công khai của service — CHỈ cần khi KHÔNG dùng Supabase (service phục vụ file qua
# GET /files/:name). Đặt = URL public của tunnel (vd https://render.example.com). Có Supabase → để TRỐNG.
SELF_PUBLIC_URL=
