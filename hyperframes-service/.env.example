# ── HyperFrames render service ──
# Cổng HTTP service lắng nghe (Docker map 8080:8080)
PORT=8080

# Bearer token bắt buộc cho POST /render. PHẢI là chuỗi ngẫu nhiên mạnh (≥32 ký tự).
# Sinh: openssl rand -hex 32
RENDER_TOKEN=

# ── Supabase Storage (nơi upload MP4 đã render) ──
# Nếu BỎ TRỐNG cả 3 dòng dưới → service trả file MP4 trực tiếp thay vì URL.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=videos

# ── Lõi render (Phase 3) ──
# RENDER_ENGINE: "playwright" = frame-stepping tự chủ. ⚠ BẮT BUỘC "playwright" để b-roll <video> Pexels
# (C2 HYBRID) chạy đúng — engine "cli" (mặc định) làm <video> ĐỨNG HÌNH. (Chỉ ảnh AI thuần thì "cli" cũng được.)
RENDER_ENGINE=playwright
# FPS render (giới hạn 12–30). 24 = cinematic (mặc định).
RENDER_FPS=24

# ── C2 HYBRID — clip b-roll Pexels thật (cảnh concept). App gửi URL clip; service tải về file local để seek. ──
# Key FREE tại pexels.com/api. App thiếu key → tự fallback ảnh AI. (Service KHÔNG bắt buộc key này để render.)
PEXELS_API_KEY=

# ── Cloudflare Tunnel — expose service ra Internet cho app Vercel (khi chạy LOCAL trên Mac) ──
# Token "remote-managed tunnel": Cloudflare Zero Trust › Networks › Tunnels › tạo tunnel → copy token.
# Public hostname của tunnel TRỎ VỀ: http://hf-render:8080 (tên service trên compose network). Xem RUN_LOCAL.md.
CLOUDFLARE_TUNNEL_TOKEN=

# (TUỲ CHỌN) URL công khai của service — CHỈ cần khi KHÔNG dùng Supabase (service phục vụ file qua
# GET /files/:name). Đặt = URL public của tunnel (vd https://render.example.com). Có Supabase → để TRỐNG.
SELF_PUBLIC_URL=
