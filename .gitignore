# Generated outputs: keep .md docs (knowledge), skip binaries (reproducible)
out/*
!out/*.md
# ...but NEVER commit the system export — it contains live secrets (Supabase keys, vault key)
out/00-SYSTEM-EXPORT.md

# Generated assets are reproducible from scripts/, skip from VCS
assets/

# Intermediate build artifacts
tsconfig.tsbuildinfo

# Dev prompt files & demo (giữ MASTER_PLAN.md/PRD.md/README.md)
CLAUDE_CODE_*.md
MANUS_SUPER_PROMPT.md
hyperframes-demo/

# Script test/scratch tạm (E2E headless, sanity test) — local-only, không commit
_*.mjs

# ───────────────────────── BẢO MẬT (thêm) ─────────────────────────
# Belt-and-suspenders: MỌI biến thể .env khác (.env.production, .env.development…) — chỉ chừa *.example
.env.*
!.env.example
# MCP config có thể chứa token (Supabase PAT) → KHÔNG commit. Muốn chia sẻ: tạo .mcp.example.json chỉ chứa ${ENV}
.mcp.json
# Khoá riêng / chứng chỉ / service-account / credential
*.pem
*.key
*.p12
*.pfx
*-private-key*
*service-account*.json
*serviceaccount*.json
*credentials*.json
secrets/
*.secret
# Bản kiểm tra/đời chạy LOCAL có thể chứa key (vd check.local.sh) — nhưng vẫn commit check.sh (zero-secret)
*.local.sh

# File tạm của render engine (bake/playwright) — sinh trong compositions/ lúc render
hyperframes-service/compositions/.render-*.html
hyperframes-service/compositions/.pw-*.html
hyperframes-service/compositions/.test-*.html
hyperframes-service/compositions/.probe.html
hyperframes-service/compositions/.smoke-*.html
