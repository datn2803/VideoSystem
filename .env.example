# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Encryption key for Credential Vault (M0)
# Generate with: openssl rand -base64 32
HUB_VAULT_KEY=

# URL công khai của app (dựng audio_url/source_url khi KHÔNG có Supabase Storage)
# Vd: https://video-system.vercel.app  (KHÔNG có dấu / ở cuối)
PUBLIC_APP_URL=

# Cost-guard: chỉ render thật (gọi D-ID/HeyGen tốn credit) khi = "1". Khác "1" → dùng mock.
RENDER_LIVE=

# Provider keys — managed qua Integration Hub UI sau khi đăng nhập
# Các key dưới chỉ là bootstrap fallback (optional)
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
HEYGEN_API_KEY=
CREATOMATE_API_KEY=

# C2 ACCURATE — logo brand thật (BLUEPRINT_C2_V2). Cờ bật: C2_ACCURATE=1.
# 2 KEY KHÁC NHAU của Logo.dev (logo.dev/docs):
#  - LOGODEV_SECRET (sk_): server-side, dùng cho Brand Search API (tên→domain). KHÔNG có → bỏ qua search, dùng KNOWN_DOMAINS + heuristic .com.
#  - LOGODEV_TOKEN  (pk_): publishable, dùng cho img.logo.dev (lấy ảnh logo theo domain). KHÔNG có → fetchBrandLogo rơi về Google favicon (độ phủ thấp hơn).
# → Set CẢ HAI để phủ logo tốt nhất (domain đúng qua Search + ảnh logo nét qua img.logo.dev).
LOGODEV_SECRET=
LOGODEV_TOKEN=
# C2_IMAGE_QUALITY=medium   # low|medium|high (ảnh C2 accurate; mặc định medium)

# C2 HYBRID — b-roll LAI: ảnh AI (brand/app-ui/product/chart) + clip VIDEO THẬT của Pexels (cảnh 'concept')
# → b-roll thật & ĐỘNG như video mẫu. Cờ bật: C2_HYBRID=1 (mặc định tắt → b-roll như hiện tại, toàn ảnh AI).
#  - Bật hybrid TỰ kéo theo điều phối accurate (cần phân loại 'concept'); brand/app-ui/chart vẫn ảnh AI.
#  - KHÔNG có PEXELS_API_KEY (hoặc Pexels miss) → cảnh concept rơi về ảnh AI (không vỡ pipeline).
#  - ⚠ Clip video b-roll CHỈ render đúng với engine frame-stepping → đặt RENDER_ENGINE=playwright trên VPS.
# PEXELS_API_KEY: lấy FREE tại pexels.com/api (200 req/giờ · 20k/tháng · $0). Endpoint /v1/videos/search.
# C2_HYBRID=1
PEXELS_API_KEY=
