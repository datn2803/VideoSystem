{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "regions": ["sin1"],
  "functions": {
    "src/app/uploads/[filename]/route.ts": {
      "maxDuration": 30
    },
    "src/app/audio/[filename]/route.ts": {
      "maxDuration": 30
    },
    "src/app/videos/[filename]/route.ts": {
      "maxDuration": 30
    }
  }
}
